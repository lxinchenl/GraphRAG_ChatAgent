OPENAI_API_KEY=your_api_key
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_CHAT_MODEL=stepfun/step-3.5-flash:free
OPENAI_TIMEOUT_SECONDS=90
OPENAI_MAX_RETRIES=2
OPENAI_RETRY_BACKOFF_SECONDS=2
EMBEDDING_PROVIDER=local
# Hub id: if project has model/models--BAAI--bge-small-zh-v1.5 (HF cache), it loads offline from snapshots/<hash>.
LOCAL_EMBED_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DEVICE=cpu
GRAPH_EXTRACT_WORKERS=4
GRAPH_PROGRESS_HEARTBEAT_SECONDS=5
ENABLE_GRAPH_ENTITY_SYNONYMS=1
ENABLE_GRAPH_MULTI_HOP=1
ENABLE_GRAPH_HIT_DEDUP=1
ENABLE_GRAPH_HIT_RERANK=1
ENABLE_GRAPH_HIT_TRUNCATE=1
GRAPH_MAX_HOPS=2
GRAPH_SYNONYMS_PER_ENTITY=2
GRAPH_TOP_K=8
GRAPH_SCORE_EXACT_MATCH_WEIGHT=3.0
GRAPH_SCORE_PARTIAL_MATCH_WEIGHT=1.5
GRAPH_SCORE_HOP_WEIGHT=1.0
GRAPH_SCORE_RELATION_WEIGHT=0.4
GRAPH_SCORE_EVIDENCE_WEIGHT=0.3
GRAPH_SCORE_SOURCE_WEIGHT=0.2
ENABLE_QUERY_REWRITE=1
ENABLE_HYBRID_RETRIEVAL=1
ENABLE_RERANK=1
ENABLE_EVIDENCE_COMPRESSION=1
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_DEVICE=cpu
RERANK_BATCH_SIZE=16
RRF_K=60
DEBUG_MODE=0
RETRIEVAL_CANDIDATE_K=12
SHORT_MEMORY_MAX_TURNS=8
LONG_MEMORY_MAX_TURNS=1000
SHORT_MEMORY_PROMPT_TURNS=3
MEMORY_RECENT_TURNS_FOR_INTENT=4
MEMORY_REUSE_SIMILARITY_THRESHOLD=0.84
LONG_MEMORY_MAX_CHARS=500
DOMAIN_KEYWORDS=数据库,关系代数,事务,范式,ER,SQL,并发,锁,隔离级别,索引,数据模型,关系模式,知识图谱

NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=please-change-me
